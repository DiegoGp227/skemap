# ================================
# Database (PostgreSQL)
# ================================
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=skemap

# DATABASE_URL se genera automáticamente en Docker con los valores de arriba.
# Para desarrollo local sin Docker:
# DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/skemap

# ================================
# Backend
# ================================
PORT=8000
BACK_PORT=8000
JWT_SECRET=your_jwt_secret_min_32_chars

# ================================
# Frontend
# ================================
FRONT_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/
